{
  "name": "battleship",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "A modern game of Battleship (player vs computer or local pass-and-play) built with Vite + TypeScript.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["battleship", "game", "typescript", "vite"],
  "author": "Michael Hamilton",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
